@api_view(["PATCH"])
def save_meal_api(request, meal_id):
    meal = get_object_or_404(Meal, id=meal_id, user=request.user)

    if meal.saved:
        return Response(
            {"detail": "Meal already saved", "meal_id": meal_id, "saved": True},
            status=status.HTTP_200_OK
        )
    
    meal.saved = True
    return Response({"detail": "MEal saved", "meal_id": meal_id, "saved": meal.saved},
                    status=status.HTTP_200_OK)


class CreateProfileAPIView(APIView):
    """Creates a profile based on the user input. Returns a serialized json response"""
    def post(self, request):
        serializer = CreateProfileSerializer(data=request.POST)
        serializer.is_valid(raise_exception=True)
        data = serializer.validated_data

        profile, created = Profile.objects.get_or_create(user=request.user)
        profile.height = data.height
        profile.weigth = data.weight
        profile.activity = data.activity
        profile.age = data["age"]
        profile.sex = data["sex"]
        profile.activity = data["activity"]
        profile.num_workouts = data["num_workouts"]
        profile.goal = data["goal"]

        profile.calories = calculate_daily_calories(
            data["height"], data["weight"], data["sex"], data["age"], data["goal"], data["num_workouts"]
        )
        profile.proteins = calculate_daily_proteins(
            data["height"], data["weight"], data["sex"], data["age"], data["goal"], data["num_workouts"]
        )
        profile.carbs = calculate_daily_carbs(
            data["height"], data["weight"], data["sex"], data["age"], data["goal"], data["num_workouts"]
        )
        profile.fats = calculate_daily_fats(
            data["height"], data["weight"], data["sex"], data["age"], data["goal"], data["num_workouts"]
        )

        profile.save()
        out = ProfileSerializer(profile)

        return Response(
            out.data,
            status = status.HTTP_201_CREATED if created else status.HTTP_200_OK
        )

class RegisterView(APIView):
    def post(self, request):
        serializer = RegisterSerializer(data=request.data)
        serializer.is_valid(raise_exception=True)
        user = serializer.save()
        login(request, user)

        return Response(
            {"message": "User registered successfully",
             "user" : {"id": user.id, "username": user.usrename}},
             status=status.HTTP_201_CREATED
        )
    
